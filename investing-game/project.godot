; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Investor Notes"
run/main_scene="uid://cufyo18yddbos"
config/features=PackedStringArray("4.7", "Mobile")
config/icon="res://icon.svg"

[autoload]

SettingsManager="*res://Scripts/Backend/Managers/SettingsManager.gd"
SaveManager="*res://Scripts/Backend/Persistence/SaveManager.gd"
PortfolioManager="*res://Scripts/Backend/Managers/PortfolioManager.gd"
